{
  "name": "passdrive",
  "version": "1.0.0",
  "private": true,
  "description": "English-first study app for the Japanese driver's license written test.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "validate:sample": "node scripts/validate-sample-data.mjs",
    "content:seed": "tsx scripts/content-store-seed.ts",
    "content:seed:sqlite": "node --env-file=.env.sqlite.local ./node_modules/tsx/dist/cli.mjs scripts/content-store-seed.ts",
    "content:seed:neon": "node --env-file=.env.neon.local ./node_modules/tsx/dist/cli.mjs scripts/content-store-seed.ts"
  },
  "keywords": [
    "nextjs",
    "typescript",
    "driving-license",
    "ipad"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "knex": "^3.1.0",
    "next": "^16.1.6",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
