      "termEn": "Right of way",
      "shortDefinitionEn": "The legal priority that determines who must go first.",
      "longExplanationEn": "At many uncontrolled intersections in Japan, you must yield to a vehicle approaching from your right unless a sign, signal, or road marking changes that rule.",
      "relatedCategoryId": "cat_right_of_way",
      "isTrafficSign": false,
      "displayOrder": 1
    },
    {
      "id": "gls_crosswalk_distance",
      "termEn": "Crosswalk stopping distance",
      "shortDefinitionEn": "The restricted distance before a crosswalk where stopping is limited.",
      "longExplanationEn": "Stopping too close to a crosswalk can block sight lines for pedestrians and drivers, so the law restricts stopping within a short distance before the crossing.",
      "relatedCategoryId": "cat_parking_stopping",
      "isTrafficSign": false,
      "displayOrder": 2
    },
    {
      "id": "gls_railroad_crossing",
      "termEn": "Railroad crossing stop",
      "shortDefinitionEn": "The required stop before entering a railroad crossing.",
      "longExplanationEn": "Before crossing the tracks, stop briefly, confirm safety, and then proceed only when the crossing is clear.",
      "relatedCategoryId": "cat_railroad_crossings",
      "isTrafficSign": false,
      "displayOrder": 3
    },
    {
      "id": "gls_no_entry_sign",
      "termEn": "No entry sign",
      "shortDefinitionEn": "A red circular sign with a white horizontal bar that prohibits entry.",
      "longExplanationEn": "This sign means vehicles must not enter from that direction. It is one of the most important prohibition signs to recognize quickly.",
      "relatedCategoryId": "cat_road_signs",
      "isTrafficSign": true,
